<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ERPMateus.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ERPMateus.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ERPMateus" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <CrossFade x:Key="MyPageTransition" Duration="0:0:0.950" />    
    </Window.Resources>
    
    <Border ClipToBounds="True">
        <TransitioningContentControl
            Background="{DynamicResource RegionBrush}"
            PageTransition="{StaticResource MyPageTransition}"
            Content="{Binding CurrentView}"/>
    </Border>
</Window>
